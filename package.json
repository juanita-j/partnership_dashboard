{
  "name": "partner-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:generate:all": "prisma generate && node scripts/prisma-generate-executive.cjs",
